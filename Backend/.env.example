NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/sft_auth
CLIENT_URL=http://localhost:5173

JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_EMAIL_SECRET=replace_with_a_long_random_email_secret
JWT_RESET_SECRET=replace_with_a_long_random_reset_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
EMAIL_TOKEN_EXPIRES_IN=1d
RESET_TOKEN_EXPIRES_IN=15m

COOKIE_DOMAIN=
COOKIE_SECURE=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Google Calendar / Meet (for auto-generating Meet links on live class creation)
# GOOGLE_REDIRECT_URI defaults to GOOGLE_CALLBACK_URL if omitted
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
GOOGLE_REFRESH_TOKEN=

ADMIN_EMAIL=admin@gyano.com
ADMIN_PASSWORD=Admin@123456

# AI Assistant (Gemini Free Tier) — get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyBIj4QXq6TeRqzLIcGnAfygJZvo93LYN-4

# Email (SMTP) — leave blank to skip sending (emails will be logged to console only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=
EMAIL_FROM="SFT Learning <noreply@sftlearning.com>"
